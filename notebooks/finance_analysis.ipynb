   "source": [
    "# Return distribution analysis\n",
    "annualized_returns = simple_returns.mean() * 252 * 100\n",
    "annualized_vol = simple_returns.std() * np.sqrt(252) * 100\n",
    "\n",
    "stats_df = pd.DataFrame({\n",
    "    'Ann. Return (%)': annualized_returns,\n",
    "    'Ann. Volatility (%)': annualized_vol,\n",
    "    'Sharpe Ratio': (annualized_returns - 5) / annualized_vol,\n",
    "    'Skewness': simple_returns.skew(),\n",
    "    'Kurtosis': simple_returns.kurtosis()\n",
    "}).sort_values('Sharpe Ratio', ascending=False)\n",
    "\n",
    "print(\"\\n📈 Asset Performance Statistics:\")\n",
    "print(stats_df.to_string())"
   ]
