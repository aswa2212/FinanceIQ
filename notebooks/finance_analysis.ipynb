    "## 6️⃣ Portfolio Optimization\n",
    "\n",
    "Apply Markowitz Mean-Variance Optimization to construct efficient portfolios."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.portfolio import (\n",
    "    max_sharpe_portfolio, min_variance_portfolio, equal_weight_portfolio,\n",
    "    efficient_frontier, monte_carlo_simulation, summary_table\n",
    ")\n",
    "\n",
    "# Use recent 3 years of data\n",
    "recent_returns = simple_returns[simple_returns.index >= '2022-01-01']\n",
    "tickers_list = list(recent_returns.columns)\n",
    "\n",
    "mu = recent_returns.mean().values\n",
    "cov = recent_returns.cov().values\n",
    "\n",
    "print(f\"📊 Optimizing portfolio with {len(tickers_list)} assets\")\n",
    "print(f\"📅 Using data from {recent_returns.index.min().date()} to {recent_returns.index.max().date()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Optimize portfolios\n",
    "print(\"\\n🔧 Running portfolio optimization...\")\n",
    "max_sharpe = max_sharpe_portfolio(mu, cov, rf=0.05)\n",
    "min_var = min_variance_portfolio(mu, cov)\n",
    "equal_w = equal_weight_portfolio(mu, cov)\n",
    "\n",
    "portfolios = {\n",
    "    'Max Sharpe': max_sharpe,\n",
    "    'Min Variance': min_var,\n",
    "    'Equal Weight': equal_w\n",
    "}\n",
    "\n",
    "print(\"\\n✅ Optimization complete!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Portfolio comparison table\n",
    "print(\"\\n📊 Portfolio Strategies Comparison:\")\n",
    "summary = summary_table(portfolios, tickers_list)\n",
    "print(summary.to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Monte Carlo + Efficient Frontier visualization\n",
    "print(\"\\n🎲 Running Monte Carlo simulation (5,000 portfolios)...\")\n",
    "mc_df = monte_carlo_simulation(mu, cov, n_portfolios=5000, rf=0.05)\n",
    "\n",
    "print(\"📈 Computing Efficient Frontier...\")\n",
    "ef_df = efficient_frontier(mu, cov, n_points=100, rf=0.05)\n",
    "\n",
    "# Plot\n",
    "fig = go.Figure()\n",
    "\n",
    "# Monte Carlo scatter\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=mc_df['Volatility']*100, \n",
    "    y=mc_df['Return']*100,\n",
    "    mode='markers',\n",
    "    marker=dict(size=4, color=mc_df['Sharpe'], colorscale='Plasma', showscale=True, \n",
    "                colorbar=dict(title=\"Sharpe\"), opacity=0.6),\n",
    "    name='Random Portfolios'\n",
    "))\n",
    "\n",
    "# Efficient Frontier\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=ef_df['Volatility']*100,\n",
    "    y=ef_df['Return']*100,\n",
    "    mode='lines',\n",
    "    line=dict(color='white', width=3),\n",
    "    name='Efficient Frontier'\n",
    "))\n",
    "\n",
    "# Special portfolios\n",
    "colors = {'Max Sharpe': '#f1c40f', 'Min Variance': '#58a6ff', 'Equal Weight': '#ffa657'}\n",
    "for name, pf in portfolios.items():\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=[pf['volatility']*100],\n",
    "        y=[pf['return']*100],\n",
    "        mode='markers',\n",
    "        marker=dict(size=15, color=colors[name], symbol='star', line=dict(color='white', width=2)),\n",
    "        name=f\"{name} (SR={pf['sharpe']:.2f})\"\n",
    "    ))\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Markowitz Efficient Frontier + Monte Carlo Simulation',\n",
    "    xaxis_title='Annualized Volatility (%)',\n",
    "    yaxis_title='Annualized Return (%)',\n",
    "    template='plotly_dark',\n",
    "    height=700,\n",
    "    hovermode='closest'\n",
    ")\n",
    "fig.show()"
   ]
